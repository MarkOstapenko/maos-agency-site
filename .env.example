# Public site URL (optional — used for sitemap, robots, Open Graph)
# Set in Vercel: Project → Settings → Environment Variables
# Example: https://your-project.vercel.app or https://maos.agency
NEXT_PUBLIC_SITE_URL=

# Contact form → Telegram (required for form submission)
# 1. Create a bot via @BotFather → copy token
# 2. Start a chat with the bot or add it to a group
# 3. Get chat_id: message the bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
